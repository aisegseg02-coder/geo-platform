      "mainEntity": [
        {
          "@type": "Question",
          "name": "شهادة توثيق التجارة الالكترونية",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "محرّكهي شركة السيو الأفضل في تهيئة وتحسين محركات البحث في الوطن العربي، وأيضاً إدارة السوشيال ميديا بالاضافة لتطوير المواقع لمساعدة موقعك في تحقيق المزيد من التقدم والوصول لأضعاف الزوار والحفاظ على النتيجة الأولى في كافة محركات البحث."
          }
        },
        {
          "@type": "Question",
          "name": "شهادة توثيق التجارة الالكترونية",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "أهلا بك في محرك!، تحسين ظهور علامتك التجارية وزيادة مبيعات متجرك الإلكتروني يكون من خلال استخدام اعلانات جوجل بفعالية. نحن نقدم لك  خدمات متميزة في تصميم وإدارة حملات إعلانات جوجل تساعدك على تحقيق أهدافك الإعلانية بأعلى كفاءة وأفضل نتائج."
          }
        }
      ]
    }
  ]
